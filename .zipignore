# Patterns excluded from capman-mcp.zip (same syntax as .gitignore)
# Processed by scripts/make-zip.js via archiver glob ignore

# Dependencies
node_modules/**

# Build output (consumers run `npm run build` themselves)
dist/**

# Export artifact itself (avoid self-inclusion)
exports/**

# TypeScript incremental cache
*.tsbuildinfo

# Editor / OS noise
.DS_Store
Thumbs.db
**/.DS_Store

# Logs
npm-debug.log*
*.log
