{
  "name": "capman-mcp",
  "version": "0.1.0",
  "description": "MCP (Model Context Protocol) adapter for capman — exposes a capman manifest as a set of MCP tools",
  "keywords": [
    "capman",
    "mcp",
    "model-context-protocol",
    "openapi",
    "llm"
  ],
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "files": [
    "dist",
    "bin",
    "demo"
  ],
  "bin": {
    "capman-mcp": "bin/capman-mcp.js"
  },
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm",
    "build:cjs": "tsc --project tsconfig.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "check": "npm run build && npm test",
    "ci": "npm run build && npm test && npm run export",
    "export": "node scripts/make-zip.js"
  },
  "peerDependencies": {
    "capman": ">=0.6.3",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.4",
    "@types/node": "^20.19.43",
    "archiver": "^5.3.2",
    "capman": "^0.6.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "zod": "^3.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod-to-json-schema": "^3.24.5"
  }
}
